{
  "entities": {
    "Post": {
      "title": "Blog Post",
      "description": "A blog post written by the student.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the post." },
        "content": { "type": "string", "description": "The markdown content of the post." },
        "excerpt": { "type": "string", "description": "A short summary of the post." },
        "authorId": { "type": "string", "description": "The UID of the author." },
        "authorName": { "type": "string", "description": "The name of the author." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "List of tags." },
        "published": { "type": "boolean", "description": "Whether the post is public." }
      },
      "required": ["title", "content", "authorId", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "A user of the blog (admin).",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of blog posts."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    }
  }
}
