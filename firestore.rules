rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: posts
    // Document ID: {postId}
    // Fields:
    //   - title: string (required, < 100 chars)
    //   - content: string (required, < 50000 chars)
    //   - excerpt: string (optional, < 500 chars)
    //   - authorId: string (required, immutable)
    //   - authorName: string (optional, < 50 chars)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //   - tags: list (optional, < 10 items, each < 20 chars)
    //   - published: bool (required)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - displayName: string (optional, < 50 chars)
    //   - email: string (required, immutable)
    //   - photoURL: string (optional, < 500 chars)
    //   - role: string (required, enum: ['admin', 'user'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "230254054@ogr.alanya.edu.tr" && request.auth.token.email_verified == true));
    }

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'createdAt', 'published']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.content is string && data.content.size() < 50000 &&
             data.authorId is string &&
             data.published is bool &&
             (!('excerpt' in data) || (data.excerpt is string && data.excerpt.size() < 500)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() < 10));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 50));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    (isAdmin() || request.resource.data.role == resource.data.role);
    }

    match /posts/{postId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create: if isAdmin() && isValidPost(request.resource.data) && request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin() && isValidPost(request.resource.data) && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isAdmin();
    }
  }
}
